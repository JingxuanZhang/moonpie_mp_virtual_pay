{
    "name": "moonpie/mp-virtual-pay",
    "version": "1.0.0",
    "description": "WeChat Mini Program Virtual Payment for EasyWeChat",
    "keywords": ["wechat", "mini-program", "virtual-payment", "easywechat"],
    "homepage": "https://github.com/JingxuanZhang/moonpie_mp_virtual_pay",
    "license": "MIT",
    "authors": [
        {
            "name": "johnzhang",
            "email": "875010341@qq.com"
        }
    ],
    "conflict": {
        "w7corp/easywechat": ">=6"
    },
    "require": {
        "php": ">=7.2",
        "overtrue/wechat": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.5"
    },
    "autoload": {
        "psr-4": {
            "Moonpie\\EasyWechat\\VirtualPay\\": "src/VirtualPay/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Moonpie\\EasyWechat\\VirtualPay\\Tests\\": "tests/VirtualPay/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "easywechat-composer/easywechat-composer": true
        }
    }
}
